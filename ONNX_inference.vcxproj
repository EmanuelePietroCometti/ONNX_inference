  <!-- Selezione del runtime ONNX in base alla configurazione:
       Debug/Release          -> pacchetto GPU (TensorRT/CUDA)
       *-OpenVINO             -> pacchetto ottimizzato OpenVINO (Intel CPU/iGPU/NPU)
       *-CPU                  -> pacchetto CPU standard (CPU Execution Provider) -->
  <PropertyGroup Label="SdkPaths">
    <SdkRoot>$(ProjectDir)SDK\</SdkRoot>
    <FmtDir>$(SdkRoot)fmt-11.1.4</FmtDir>
    <OpenCVDir>$(SdkRoot)opencv\build</OpenCVDir>
    <JsonDir>$(SdkRoot)nlohmann_json</JsonDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug' or '$(Configuration)'=='Release'">
    <OrtDir>$(SdkRoot)onnxruntime-win-x64-gpu-1.24.4</OrtDir>
    <OrtEpDefine>ORT_EP_GPU</OrtEpDefine>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug-OpenVINO' or '$(Configuration)'=='Release-OpenVINO'">
    <OrtDir>$(SdkRoot)onnxruntime_openvino</OrtDir>
    <OrtEpDefine>ORT_EP_OPENVINO</OrtEpDefine>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug-CPU' or '$(Configuration)'=='Release-CPU'">
    <OrtDir>$(SdkRoot)onnxruntime-win-x64-1.24.4</OrtDir>
    <OrtEpDefine>ORT_EP_CPU</OrtEpDefine>
  </PropertyGroup>
